generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id             Int       @id @default(autoincrement())
  name           String
  commercialName String?
  taxId          String    @unique
  phone          String?
  address        String?
  receptionEmail String?
  logo           String?
  website        String?
  description    String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  branches       Branch[]
  patients       Patient[]
  services       Service[]
  users          User[]
  consentTemplates ConsentTemplate[]
  payments       Payment[]
  invoices       Invoice[]
}

model Branch {
  id           Int           @id @default(autoincrement())
  name         String
  address      String?
  phone        String?
  companyId    Int
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  company      Company       @relation(fields: [companyId], references: [id])
  users        User[]
  consultories Consultory[]
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  password       String
  name           String
  role           Role            @default(DENTIST)
  active         Boolean         @default(true)
  companyId      Int
  branchId       Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  appointments   Appointment[]   @relation("DoctorAppointments")
  clinicalForms  ClinicalForm[]  @relation("DoctorClinicalForms")
  odontogramLogs OdontogramLog[] @relation("DoctorOdontogramLogs")
  treatmentPlans TreatmentPlan[] @relation("DoctorTreatments")
  branch         Branch?         @relation(fields: [branchId], references: [id])
  company        Company         @relation(fields: [companyId], references: [id])
}

model Patient {
  id                 Int             @id @default(autoincrement())
  firstName          String
  lastName           String
  paternalSurname    String?
  maternalSurname    String?
  documentType       String          @default("DNI")
  documentId         String?         @unique
  nationality        String?         @default("Peruano")
  birthDate          DateTime
  gender             String          @default("SIN ESPECIFICAR")
  civilStatus        String?         @default("SIN ESPECIFICAR")
  phoneMobile        String?
  phoneHome          String?
  phone              String?
  email              String?
  webUser            String?
  webPassword        String?
  whatsappEnabled    Boolean         @default(true)
  ubigeoAddress      String?
  ubigeoCode         String?
  address            String?
  reference          String?
  medicalHistory     String?
  active             Boolean         @default(true)
  companyId          Int
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  additionalInfo     String?
  allergies          String?
  birthCountry       String?         @default("Perú")
  fiscalData         Json?
  guardianDocumentId String?
  guardianName       String?
  guardianPhone      String?
  hasGuardian        Boolean         @default(false)
  hcNumber           String?         @unique
  insurance          String?
  leadSource         String?
  lineOfBusiness     String?
  nickname           String?
  notes              String?
  occupation         String?
  tags               String?
  appointments       Appointment[]
  clinicalForms      ClinicalForm[]
  odontograms        Odontogram[]
  odontogramLogs     OdontogramLog[]
  company            Company         @relation(fields: [companyId], references: [id])
  treatmentPlans     TreatmentPlan[]
  consents           PatientConsent[]
  patientFiles       PatientFile[]
}

model Appointment {
  id             Int             @id @default(autoincrement())
  date           DateTime
  status         String          @default("SCHEDULED")
  reason         String?
  urgency        String          @default("NORMAL")
  duration       Int             @default(30)
  notes          String?
  patientId      Int
  doctorId       Int
  branchId       Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  branch         Branch          @relation(fields: [branchId], references: [id])
  doctor         User            @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient        Patient         @relation(fields: [patientId], references: [id])
  treatmentItems TreatmentItem[]
  consultoryId   Int?
  consultory     Consultory?     @relation(fields: [consultoryId], references: [id])
}

model Service {
  id             Int             @id @default(autoincrement())
  name           String
  category       String
  description    String?
  price          Float
  duration       Int             @default(30)
  active         Boolean         @default(true)
  companyId      Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  company        Company         @relation(fields: [companyId], references: [id])
  treatmentItems TreatmentItem[]
}

model TreatmentPlan {
  id           Int             @id @default(autoincrement())
  patientId    Int
  doctorId     Int
  name         String?
  status       String          @default("PENDING")
  discount     Float           @default(0)
  notes        String?
  notesPatient String?
  notesInternal String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  items        TreatmentItem[]
  payments     Payment[]
  doctor       User            @relation("DoctorTreatments", fields: [doctorId], references: [id])
  patient      Patient         @relation(fields: [patientId], references: [id])
  invoices     Invoice[]       @relation("TreatmentInvoices")
}

model TreatmentItem {
  id              Int            @id @default(autoincrement())
  treatmentPlanId Int?
  serviceId       Int
  toothNumber     String?
  price           Float
  quantity        Int            @default(1)
  discount        Float          @default(0)
  status          String         @default("PENDING")
  appointmentId   Int?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  appointment     Appointment?   @relation(fields: [appointmentId], references: [id])
  service         Service        @relation(fields: [serviceId], references: [id])
  treatmentPlan   TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id])
}

model Invoice {
  id              Int             @id @default(autoincrement())
  number          String          @unique
  type            String          @default("BOLETA") // BOLETA, FACTURA
  status          String          @default("PAID")   // PAID, VOID
  total           Float
  patientId       Int
  companyId       Int
  treatmentPlanId Int?
  createdAt       DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  treatmentPlan   TreatmentPlan?  @relation("TreatmentInvoices", fields: [treatmentPlanId], references: [id])
  company         Company         @relation(fields: [companyId], references: [id])
}

model Payment {
  id              Int            @id @default(autoincrement())
  amount          Float
  method          String         @default("CASH") // CASH, CARD, TRANSFER
  reference       String?
  treatmentPlanId Int?
  appointmentId   Int?
  companyId       Int
  createdAt       DateTime       @default(now())
  treatmentPlan   TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id])
  company         Company        @relation(fields: [companyId], references: [id])
}

model Odontogram {
  id        Int      @id @default(autoincrement())
  data      Json
  patientId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model OdontogramLog {
  id          Int      @id @default(autoincrement())
  patientId   Int
  toothNumber String
  conditionId String?
  action      String
  description String?
  doctorId    Int
  createdAt   DateTime @default(now())
  doctor      User     @relation("DoctorOdontogramLogs", fields: [doctorId], references: [id])
  patient     Patient  @relation(fields: [patientId], references: [id])
}

model ClinicalForm {
  id        Int      @id @default(autoincrement())
  type      String
  data      Json
  patientId Int
  doctorId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    User     @relation("DoctorClinicalForms", fields: [doctorId], references: [id])
  patient   Patient  @relation(fields: [patientId], references: [id])

  @@unique([patientId, type])
}

enum Role {
  ADMIN
  DENTIST
  RECEPTIONIST
  ASSISTANT
}

model Consultory {
  id        Int           @id @default(autoincrement())
  name      String
  branchId  Int
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  branch    Branch        @relation(fields: [branchId], references: [id])
  appointments Appointment[]
}

model ConsentTemplate {
  id        Int              @id @default(autoincrement())
  title     String
  content   String           @db.Text
  active    Boolean          @default(true)
  companyId Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  company   Company          @relation(fields: [companyId], references: [id])
  consents  PatientConsent[]
}

model PatientConsent {
  id         Int             @id @default(autoincrement())
  patientId  Int
  templateId Int
  signature  String?         @db.Text // Base64 signature
  fileUrl    String?         // Cloudinary URL for signed document
  signedAt   DateTime        @default(now())
  patient    Patient         @relation(fields: [patientId], references: [id])
  template   ConsentTemplate @relation(fields: [templateId], references: [id])
}

model PatientFile {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  type      String?  // image, pdf, etc.
  patientId Int
  patient   Patient  @relation(fields: [patientId], references: [id])
  createdAt DateTime @default(now())
}
